# API
EXPO_PUBLIC_API_BASE_URL=https://coach-api-production-fc12.up.railway.app/api/v1

# Telegram
EXPO_PUBLIC_TELEGRAM_BOT_USERNAME=Coach_for_Sumiya_bot

# Firebase JS SDK — m-coach-ai project
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=m-coach-ai
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=m-coach-ai.firebaseapp.com
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=m-coach-ai.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In — m-coach-ai project
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# RevenueCat — Coach Pro entitlement
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=

# MVP v1 feature flags
# Set to 'false' to unlock voice logging, AI chat, workouts, body composition, weekly summary.
# Leave unset or set to 'true' for production App Store builds (MVP scope).
EXPO_PUBLIC_MVP_V1=true
