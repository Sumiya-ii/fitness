{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": {
        "simulator": false
      },
      "env": {
        "SENTRY_ORG": "nexus-kairos",
        "SENTRY_PROJECT": "react-native"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "ios": {
        "buildConfiguration": "Release"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "SENTRY_ORG": "nexus-kairos",
        "SENTRY_PROJECT": "react-native"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "founder@nexuskairos.com",
        "ascAppId": "6761208992",
        "appleTeamId": "DZ9RLGDX2M"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "production"
      }
    }
  }
}
