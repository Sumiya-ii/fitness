# ===================================
# Coach - Environment Variables
# ===================================
# Copy this file to .env and fill in the values.
# Required variables are marked with [REQUIRED].

# --- General ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL [REQUIRED] ---
DATABASE_URL=postgresql://coach:coach@localhost:5432/coach

# --- Redis [REQUIRED] ---
REDIS_URL=redis://localhost:6379

# --- Firebase Auth [REQUIRED] ---
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-admin@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# --- Telegram Bot (optional for local dev) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- S3-compatible Object Storage (optional for local dev) ---
S3_BUCKET=coach-media
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=http://localhost:9000

# --- Typesense (optional for local dev) ---
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=

# --- STT Providers (optional for local dev) ---
GOOGLE_STT_CREDENTIALS=
CHIMEGE_API_KEY=

# --- Observability (optional for local dev) ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- PostHog (optional for local dev) ---
POSTHOG_API_KEY=
POSTHOG_HOST=
