# ===================================
# Coach - Environment Variables
# ===================================
# Copy this file to .env and fill in the values.
# Required variables are marked with [REQUIRED].

# --- General ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL [REQUIRED] ---
DATABASE_URL=postgresql://coach:coach@localhost:5432/coach

# --- Redis [REQUIRED] ---
REDIS_URL=redis://localhost:6379

# --- Firebase Auth [REQUIRED] ---
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-admin@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# --- Admin Access (optional) ---
# Comma-separated user UUIDs allowed to use /api/v1/admin endpoints
ADMIN_USER_IDS=

# --- Bull Board dashboard credentials ---
# Protects /admin/queues with HTTP Basic Auth
# Change these before deploying to production!
BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=admin

# --- Telegram Bot (optional for local dev) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- S3-compatible Object Storage (optional for local dev) ---
S3_BUCKET=coach-media
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=http://localhost:9000

# --- STT ---
# Voice meal logging uses OpenAI gpt-4o-transcribe (configured via OPENAI_API_KEY above).

# --- Vision Provider (for food photo calorie analysis) ---
# VISION_PROVIDER: 'gemini' (default) | 'openai'
# When 'gemini': Gemini 2.0 Flash is used as primary; GPT-4o is automatic fallback if Gemini fails
# When 'openai': GPT-4o only, no fallback
VISION_PROVIDER=gemini
GEMINI_API_KEY=

# --- OpenAI (GPT-4o fallback for vision, also used for other AI features) ---
OPENAI_API_KEY=

# --- Observability (optional for local dev) ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- PostHog (optional for local dev) ---
POSTHOG_API_KEY=
POSTHOG_HOST=

# --- RevenueCat (required for iOS in-app subscriptions) ---
# Set the webhook Authorization header value in:
# RevenueCat Dashboard → Project → Integrations → Webhooks → Authorization header
REVENUECAT_WEBHOOK_SECRET=

# --- QPay Payment (optional for local dev) ---
# Get credentials from QPay: info@qpay.mn
QPAY_API_URL=https://merchant-sandbox.qpay.mn/v2
QPAY_CLIENT_ID=
QPAY_CLIENT_SECRET=
QPAY_INVOICE_CODE=
# Optional shared secret appended to callback URL and verified on callback
QPAY_CALLBACK_TOKEN=
# Pending invoice expiration in minutes (default 30)
QPAY_INVOICE_TTL_MINUTES=30

# --- Mobile (Expo public env vars) ---
# Set these when running apps/mobile. They are safe to expose to clients.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
EXPO_PUBLIC_TELEGRAM_BOT_USERNAME=CoachBot
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_TERMS_URL=https://www.nexuskairos.com/coach/terms
EXPO_PUBLIC_PRIVACY_URL=https://www.nexuskairos.com/coach/privacy
EXPO_PUBLIC_SUPPORT_URL=https://www.nexuskairos.com/coach/support
EXPO_PUBLIC_SENTRY_DSN=
# RevenueCat iOS public key (get from RC Dashboard → Project → API Keys → Public app-specific key)
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
# Used by EAS build to upload source maps to Sentry (set as an EAS secret via: eas secret:create SENTRY_AUTH_TOKEN)
SENTRY_AUTH_TOKEN=
