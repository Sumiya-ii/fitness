# ===================================
# Coach - Environment Variables
# ===================================
# Copy this file to .env and fill in the values.
# Required variables are marked with [REQUIRED].

# --- General ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL [REQUIRED] ---
DATABASE_URL=postgresql://coach:coach@localhost:5432/coach

# --- Redis [REQUIRED] ---
REDIS_URL=redis://localhost:6379

# --- Firebase Auth [REQUIRED] ---
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-admin@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# --- Admin Access (optional) ---
# Comma-separated user UUIDs allowed to use /api/v1/admin endpoints
ADMIN_USER_IDS=

# --- Telegram Bot (optional for local dev) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- S3-compatible Object Storage (optional for local dev) ---
S3_BUCKET=coach-media
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=http://localhost:9000

# --- Typesense (optional for local dev) ---
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=

# --- STT Providers (optional for local dev) ---
# STT_PROVIDER: 'google' | 'chimege' (defaults to google if GOOGLE_STT_API_KEY is set)
STT_PROVIDER=google
GOOGLE_STT_API_KEY=
GOOGLE_STT_CREDENTIALS=
CHIMEGE_API_KEY=

# --- OpenAI (for photo food recognition via GPT-4 Vision) ---
OPENAI_API_KEY=

# --- Observability (optional for local dev) ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- PostHog (optional for local dev) ---
POSTHOG_API_KEY=
POSTHOG_HOST=

# --- QPay Payment (optional for local dev) ---
# Get credentials from QPay: info@qpay.mn
QPAY_API_URL=https://merchant-sandbox.qpay.mn/v2
QPAY_CLIENT_ID=
QPAY_CLIENT_SECRET=
QPAY_INVOICE_CODE=
# Optional shared secret appended to callback URL and verified on callback
QPAY_CALLBACK_TOKEN=
# Pending invoice expiration in minutes (default 30)
QPAY_INVOICE_TTL_MINUTES=30

# --- Mobile (Expo public env vars) ---
# Set these when running apps/mobile. They are safe to expose to clients.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
EXPO_PUBLIC_TELEGRAM_BOT_USERNAME=CoachBot
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_TERMS_URL=
EXPO_PUBLIC_PRIVACY_URL=
EXPO_PUBLIC_SENTRY_DSN=
# Used by EAS build to upload source maps to Sentry (set as an EAS secret via: eas secret:create SENTRY_AUTH_TOKEN)
SENTRY_AUTH_TOKEN=
